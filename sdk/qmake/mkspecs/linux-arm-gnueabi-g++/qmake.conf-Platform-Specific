# qmake.conf for ARM Linux with GLIBC
# Platform-specific configuration for BBB AI-64

# ============================================================================
# Include Base Configuration
# ============================================================================
include(../common/linux.conf)
include(../common/gcc-base-unix.conf)
include(../common/g++-unix.conf)

# ============================================================================
# Compiler Settings
# ============================================================================
# Cross-compiler prefix
CROSS_COMPILE = arm-poky-linux-gnueabi-

QMAKE_CC                = $$CROSS_COMPILE}gcc
QMAKE_CXX               = $$CROSS_COMPILE}g++
QMAKE_LINK              = $$CROSS_COMPILE}g++
QMAKE_LINK_SHLIB        = $$CROSS_COMPILE}g++
QMAKE_AR                = $$CROSS_COMPILE}ar cqs
QMAKE_OBJCOPY           = $$CROSS_COMPILE}objcopy
QMAKE_STRIP             = $$CROSS_COMPILE}strip
QMAKE_RANLIB            = $$CROSS_COMPILE}ranlib
QMAKE_NM                = $$CROSS_COMPILE}nm

# ============================================================================
# Sysroot
# ============================================================================
QMAKE_DEFAULT_SYSROOT = /opt/poky/1.0/sysroots/cortexa72-poky-linux

# ============================================================================
# Compiler Flags
# ============================================================================
QMAKE_CFLAGS            = -O2 -pipe -g -feliminate-unused-debug-types
QMAKE_CXXFLAGS          = -O2 -pipe -g -feliminate-unused-debug-types

# ARM Cortex-A72 specific
QMAKE_CFLAGS            += -mcpu=cortex-a72 -mtune=cortex-a72 -mfpu=neon -mfloat-abi=hard
QMAKE_CXXFLAGS          += -mcpu=cortex-a72 -mtune=cortex-a72 -mfpu=neon -mfloat-abi=hard

# Security hardening
QMAKE_CFLAGS            += -fstack-protector-strong -fPIE
QMAKE_CXXFLAGS          += -fstack-protector-strong -fPIE

# ============================================================================
# Linker Flags
# ============================================================================
QMAKE_LFLAGS            = -Wl,-rpath-link,$$QMAKE_DEFAULT_SYSROOT/usr/lib
QMAKE_LFLAGS            += -Wl,-z,relro,-z,now
QMAKE_LFLAGS            += -Wl,--no-undefined

# ============================================================================
# Include and Library Paths
# ============================================================================
QMAKE_INCDIR            = $$QMAKE_DEFAULT_SYSROOT/usr/include
QMAKE_INCDIR_QT         = $$QMAKE_DEFAULT_SYSROOT/usr/include/qt6
QMAKE_INCDIR_OPENGL     = $$QMAKE_DEFAULT_SYSROOT/usr/include/GL
QMAKE_INCDIR_OPENGL_ES2 = $$QMAKE_DEFAULT_SYSROOT/usr/include/GLES2
QMAKE_INCDIR_EGL        = $$QMAKE_DEFAULT_SYSROOT/usr/include

QMAKE_LIBDIR            = $$QMAKE_DEFAULT_SYSROOT/usr/lib
QMAKE_LIBDIR_QT         = $$QMAKE_DEFAULT_SYSROOT/usr/lib
QMAKE_LIBDIR_OPENGL     = $$QMAKE_DEFAULT_SYSROOT/usr/lib

# ============================================================================
# End of qmake.conf
# ============================================================================
