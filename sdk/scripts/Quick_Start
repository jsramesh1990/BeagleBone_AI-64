# ============================================================================
# Create Documentation
# ============================================================================
create_documentation() {
    print_info "Creating documentation..."
    
    mkdir -p "$SDK_DIR/docs"
    
    cat > "$SDK_DIR/docs/sdk-guide.md" << 'EOF'
# BBB AI-64 SDK Guide

## Overview

The BBB AI-64 SDK provides a complete development environment for creating applications for the BeagleBone Black AI-64 platform.

## Quick Start

1. Source the environment:
   ```bash
   source sdk/environment-setup.sh

    Build an example:
    bash

    cd sdk/examples/hello-world
    make

    Deploy to target:
    bash

    bbbsdk-deploy <board-ip> hello

Documentation

For complete documentation, see the main documentation in the docs/ directory.
EOF

print_success "Documentation created in $SDK_DIR/docs/"
}
